#!/usr/bin/make -f

%:
	dh $@

override_dh_clean:
	dh_clean -XCargo.toml.orig

override_dh_auto_build:
	sh scripts/check-rust-version.sh
	CARGO_NET_OFFLINE=true cargo build --frozen --offline --release

override_dh_auto_test:
	CARGO_NET_OFFLINE=true cargo test --frozen --offline

override_dh_installsystemd:
	dh_installsystemd --no-enable --no-start

override_dh_auto_install:
	install -Dm755 target/release/boxup debian/boxup/usr/bin/boxup
	install -Dm755 target/release/boxup-root debian/boxup/usr/lib/boxup/boxup-root
	install -Dm755 scripts/setup-profile.sh debian/boxup/usr/lib/boxup/setup-profile
	install -Dm644 LICENSE debian/boxup/usr/share/doc/boxup/LICENSE
	install -Dm644 vendor/THIRD_PARTY_NOTICES debian/boxup/usr/share/doc/boxup/THIRD_PARTY_NOTICES
	install -d debian/boxup/usr/lib/systemd/system
	install -m644 packaging/systemd/* debian/boxup/usr/lib/systemd/system/
	install -Dm644 packaging/polkit/org.boxup.policy debian/boxup/usr/share/polkit-1/actions/org.boxup.policy
	install -Dm644 examples/desktop.toml debian/boxup/usr/share/doc/boxup/examples/desktop.toml
	install -Dm644 examples/ubuntu-docker-vps.toml debian/boxup/usr/share/doc/boxup/examples/ubuntu-docker-vps.toml
	install -Dm644 README.md debian/boxup/usr/share/doc/boxup/README.md
	install -Dm644 AGENTS.md debian/boxup/usr/share/doc/boxup/AGENTS.md
	install -Dm644 docs/RESTORE.md debian/boxup/usr/share/doc/boxup/RESTORE.md
	install -Dm644 docs/RESTORE.md debian/boxup/usr/share/doc/boxup/docs/RESTORE.md
	install -Dm644 SECURITY.md debian/boxup/usr/share/doc/boxup/SECURITY.md
